    <string name="privacy_policy"><![CDATA[<b>Vie privée:</b><br/>Suntimes ne collecte, enregistre, ou transmet aucune donnée peronnelle. Ne contient <b>pas de publicité</b>, <b>pas d\'analyse des données</b>, <b>pas de traceur</b>, et <b>pas d\'autorisation inutile</b>. <br/><br/>L\'application utilise les données de localisation. Ces informations (ainsi que les autres données utilisées par l\'application) sont stockées localement et ne quittent pas l\'appareil.<br/><br/><xliff:g id="permissionsExplained">%1$s</xliff:g>]]></string>
    <string name="privacy_permission_calendar"><![CDATA[Suntimes utilise les autorisations de <b>calendrier</b> pour s\'intégrer à l\'application Calendrier. Ces autorisations permettent à l\'application de créer des calendriers et des événements personnalisés.<br/><br/>Des autorisations sont également requises pour désactiver l\'intégration au calendrier (afin de supprimer les calendriers personnalisés).]]></string>
    <string name="privacy_permissiondialog_title">Permissions</string>

